{
  "compilerOptions": {
    "types": ["node"],
        "target": "es2015", 
    "lib": ["es2015", "dom", "dom.iterable", "scripthost"],
    "composite": true,    
    "noEmit": false,      
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo",
    "module": "ESNext",
